# Normalization Quest Lab - Environment Configuration

# Backend (Laravel)
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.dataquest.com
APP_KEY=base64:GENERATE_THIS_WITH_php_artisan_key_generate

DB_CONNECTION=pgsql
DB_HOST=vps.dataquest.com
DB_PORT=5432
DB_DATABASE=dataquest
DB_USERNAME=secure_user
DB_PASSWORD=complex_password

BCRYPT_ROUNDS=12
SESSION_SECURE=true
CSRF_PROTECTION=true

# Cache and Queue
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=vps.dataquest.com
REDIS_PASSWORD=redis_password
REDIS_PORT=6379

# Mail Configuration (optional)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=your_username
MAIL_PASSWORD=your_password

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=notice

# Frontend (React/Vite)
VITE_API_URL=https://api.dataquest.com
VITE_VERCEL_ANALYTICS=true
VITE_APP_NAME=Normalization Quest Lab
