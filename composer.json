{
  "name": "dataquest/normalization-quest-lab",
  "description": "Interactive educational platform for database normalization learning",
  "type": "project",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^12.61",
    "laravel/tinker": "^2.8"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "laravel/pint": "^1.13",
    "fakerphp/faker": "^1.23"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "scripts": {
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
    ]
  }
}
